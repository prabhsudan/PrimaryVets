<style>
    .header-bar {
        position: sticky;
        top: 0;
        background: #fff;
        z-index: 100;
        display: flex;
        align-items: center;
        height: 60px;
    }

    /* Back button stays left */
    .back-btn {
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: #f5f7fb;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    /* PERFECT CENTER TITLE */
    .page-title {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-size: 18px;
        font-weight: 700;
        margin: 0;
    }
</style>
<div class="sticky-top bg-white border-bottom py-2 px-3 header-bar">

    <button class="back-btn"
            onclick="history.back()">
        <i class="bi bi-arrow-left"></i>
    </button>

    <h2 class="page-title mb-0">
        Pet Vaccination Details
    </h2>

</div>
<div class="container my-4">

    <!-- PET + VACCINE HEADER CARD -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body d-flex align-items-center justify-content-between">

            <div class="d-flex align-items-center gap-3">
                <img src="~/images/Tommy.jpg"
                     class="rounded-circle border"
                     width="70" height="70"
                     style="object-fit:cover;" />

                <div>
                    <h5 class="mb-0 fw-bold">Tommy</h5>
                    <small class="text-muted">Rabies Vaccine • Booster</small>
                </div>
            </div>

            <span class="badge bg-success px-3 py-2 rounded-pill">
                Completed
            </span>
        </div>
    </div>


    <!-- INFO GRID: Vaccine Details -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Vaccine Type</small>
                <h6 class="fw-bold mb-0">Rabies</h6>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Dose</small>
                <h6 class="fw-bold mb-0">2nd Booster</h6>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Date</small>
                <h6 class="fw-bold mb-0">16 May 2026</h6>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
                <small class="text-muted">Next Due</small>
                <h6 class="fw-bold mb-0 text-warning">22 May 2026</h6>
            </div>
        </div>

    </div>


    <!-- PET | OWNER INFO -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <h6 class="fw-bold mb-3">Pet & Owner Info</h6>

            <div class="row">
                <div class="col-md-6">
                    <p class="mb-1"><strong>Pet:</strong> Tommy (Dog)</p>
                    <p class="mb-0"><strong>Breed:</strong> Labrador</p>
                </div>

                <div class="col-md-6">
                    <p class="mb-1"><strong>Owner:</strong> Rahul Sharma</p>
                    <p class="mb-0"><strong>Contact:</strong> +91 98XXXXXX21</p>
                </div>
            </div>

        </div>
    </div>


    <!-- DOCTOR INFO -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <h6 class="fw-bold mb-3">Doctor Info</h6>

            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;">
                    DR
                </div>

                <div>
                    <h6 class="mb-0">Dr. Mehta</h6>
                    <small class="text-muted">Veterinary Specialist</small>
                </div>
            </div>

        </div>
    </div>


    <!-- STATUS TIMELINE -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <h6 class="fw-bold mb-3">Status Timeline</h6>

            <ul class="list-group list-group-flush">

                <li class="list-group-item d-flex justify-content-between">
                    <span>Registered & Vacine Given</span>
                    <small class="text-muted">10 May</small>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span>Vaccine Given</span>
                    <small class="text-muted">16 May</small>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Vaccine Pending</span>
                    <small class="text-muted">22 May</small>
                </li>

                <li class="list-group-item d-flex justify-content-between">
                    <span>Completed</span>
                    <small class="text-success fw-bold">(2/3)</small>
                </li>

            </ul>

        </div>
    </div>


    <!-- NOTES -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <h6 class="fw-bold mb-2">Notes</h6>
            <p class="mb-0 text-muted">
                No side effects observed. Pet is healthy and active after vaccination.
            </p>

        </div>
    </div>


    <!-- ACTION BUTTONS -->
    <div class="d-flex gap-2 justify-content-end">

        <button class="btn btn-outline-primary rounded-3">
            Edit
        </button>

        <button class="btn btn-success rounded-3">
            Add Reminder
        </button>

        <button class="btn btn-danger rounded-3">
            Delete
        </button>

    </div>

</div>