<style>

    body {
        background: #f5f7fb;
    }

    .staff-card {
        max-width: 750px;
        margin: auto;
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        background: white;
    }

    .staff-header {
        background: linear-gradient(135deg, #396afc, #2948ff);
        padding: 40px 20px 75px;
        text-align: center;
        color: white;
        position: relative;
    }

    .staff-title {
        font-size: 24px;
        font-weight: 700;
    }

    .staff-subtitle {
        font-size: 14px;
        opacity: 0.85;
    }

    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 5px 12px;
        font-size: 12px;
        border-radius: 20px;
        font-weight: 600;
        color: white;
        background: #22c55e;
    }

    .staff-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid white;
        position: absolute;
        left: 50%;
        bottom: -60px;
        transform: translateX(-50%);
        box-shadow: 0 6px 18px rgba(0,0,0,0.25);
        background: white;
    }

    .staff-body {
        padding: 85px 25px 25px;
    }

    .section-title {
        font-size: 13px;
        font-weight: 700;
        color: #0D52BD;
        margin: 18px 0 10px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .info-box {
        background: #f9fafb;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    .label {
        font-size: 12px;
        color: #6b7280;
    }

    .value {
        font-weight: 600;
        color: #111;
    }

    .edit-field {
        display: none;
        margin-top: 6px;
    }

    .edit-status {
        display: none;
        position: absolute;
        top: 15px;
        right: 15px;
        width: 140px;
    }

    .action-bar {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-action {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        color: white;
        cursor: pointer;
    }

    .btn-call {
        background: #22c55e;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-task {
        background: #3b82f6;
    }

    .header-bar {
        position: sticky;
        top: 0;
        background: #fff;
        z-index: 100;
        display: flex;
        align-items: center;
        height: 60px;
        padding: 0 12px;
        border-bottom: 1px solid #eee;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: #f5f7fb;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .page-title {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-size: 18px;
        font-weight: 700;
    }

</style>

<!-- TOP BAR -->
<div class="header-bar">
    <button class="back-btn" onclick="history.back()">
        <i class="bi bi-arrow-left"></i>
    </button>

    <h2 class="page-title">Staff Details</h2>
</div>

<br />

<!-- STAFF CARD -->
<div class="card staff-card">

    <!-- HEADER -->
    <div class="staff-header">

        <!-- STATUS -->
        <div class="status-badge view-status">On Duty</div>

        <select class="form-select edit-status">
            <option>On Duty</option>
            <option>Off Duty</option>
            <option>Leave</option>
        </select>

        <!-- NAME (ALWAYS VIEW) -->
        <div class="staff-title">Dr. Amit Sharma</div>

        <!-- SUBTITLE (ALWAYS VIEW) -->
        <div class="staff-subtitle">Veterinarian • Surgery Department</div>

        <img src="~/images/staff.jpg" class="staff-avatar" />

    </div>

    <!-- BODY -->
    <div class="staff-body">

        <div class="section-title">Staff Information</div>

        <div class="info-grid">

            <div class="info-box">
                <div class="label">Employee ID</div>
                <div class="value">VET-1024</div>
                <input type="text" class="form-control edit-field" value="VET-1024" />
            </div>

            <div class="info-box">
                <div class="label">Mobile</div>
                <div class="value">9876543210</div>
                <input type="text" class="form-control edit-field" value="9876543210" />
            </div>

            <div class="info-box">
                <div class="label">Shift</div>
                <div class="value">Morning (8AM - 2PM)</div>
                <input type="text" class="form-control edit-field" value="Morning (8AM - 2PM)" />
            </div>

            <div class="info-box">
                <div class="label">Experience</div>
                <div class="value">6 Years</div>
                <input type="text" class="form-control edit-field" value="6 Years" />
            </div>

        </div>

        <div class="section-title">Work Status</div>

        <div class="info-grid">

            <div class="info-box">
                <div class="label">Current Cases</div>
                <div class="value">5 Patients</div>
                <input type="text" class="form-control edit-field" value="5 Patients" />
            </div>

            <div class="info-box">
                <div class="label">Completed Today</div>
                <div class="value">3 Treatments</div>
                <input type="text" class="form-control edit-field" value="3 Treatments" />
            </div>

        </div>

        <!-- ACTIONS -->
        <div class="action-bar">

            <a href="/Appointment/Create"
               class="btn-action btn-task text-decoration-none d-flex align-items-center justify-content-center">
                Assigned Task
            </a>

            <button id="editBtn" class="btn-action btn-edit">Edit</button>

            <button id="saveBtn" class="btn-action btn-task" style="display:none;">Save</button>

            <button id="cancelBtn" class="btn-action btn-call" style="display:none;">Cancel</button>

        </div>

    </div>

</div>

<!-- JS -->
<script>

    const editBtn = document.getElementById("editBtn");
    const saveBtn = document.getElementById("saveBtn");
    const cancelBtn = document.getElementById("cancelBtn");

    editBtn.addEventListener("click", function () {

        document.querySelectorAll(".value").forEach(el => {
            el.style.display = "none";
        });

        document.querySelectorAll(".edit-field").forEach(el => {
            el.style.display = "block";
        });

        document.querySelectorAll(".view-status").forEach(el => {
            el.style.display = "none";
        });

        document.querySelectorAll(".edit-status").forEach(el => {
            el.style.display = "block";
        });

        editBtn.style.display = "none";
        saveBtn.style.display = "inline-block";
        cancelBtn.style.display = "inline-block";
    });

    cancelBtn.addEventListener("click", function () {

        document.querySelectorAll(".value").forEach(el => {
            el.style.display = "block";
        });

        document.querySelectorAll(".edit-field").forEach(el => {
            el.style.display = "none";
        });

        document.querySelectorAll(".view-status").forEach(el => {
            el.style.display = "block";
        });

        document.querySelectorAll(".edit-status").forEach(el => {
            el.style.display = "none";
        });

        editBtn.style.display = "inline-block";
        saveBtn.style.display = "none";
        cancelBtn.style.display = "none";
    });

</script>