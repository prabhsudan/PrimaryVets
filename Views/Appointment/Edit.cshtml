@model PrimaryVets.Models.AppointmentDetailVM
@{
    ViewData["Title"] = "Edit Appointment";
}
<style>
    body {
        background-color: #f4f6f9;
    }

    .appointment-container {
        max-width: 1000px;
        margin: 40px auto;
    }

    .appointment-card {
        background: #fff;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .page-title {
        font-weight: 700;
        color: #2c3e50;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 6px;
    }
</style>

<div class="container appointment-container">

    <div class="appointment-card">

        <div class="mb-4">
            <h2 class="page-title">Edit Appointment</h2>
            <p class="text-muted mb-0">
                Update appointment details and information.
            </p>
        </div>

        <form asp-action="Edit" asp-controller="Appointment" method="post">
            <div class="row g-3 mb-3">
                <div class="col-12 col-md-4">
                    <label asp-for="AppointmentDate" class="form-label"> Appointment Date</label>
                    <input asp-for="AppointmentDate" class="form-control" type="date" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="TimeSlot" class="form-label"> TimeSlot </label>
                    <input asp-for="TimeSlot" type="time" class="form-control" />
                    <span asp-validation-for="TimeSlot" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="AppointmentType" class="form-label">Appointment Type</label>
                    <select asp-for="AppointmentType" class="form-select">
                        <option value="">Select Appointment</option>
                        <option value="Vaccination">Vaccination</option>
                        <option value="Surgery">Surgery</option>
                        <option value="Checkup">Checkup</option>
                        <option value="Emergency">Emergency</option>
                    </select>
                    <span asp-validation-for="AppointmentType" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-12 col-md-4">
                    <label asp-for="DoctorName" class="form-label"> Doctor Name </label>
                    <input asp-for="DoctorName" class="form-control" placeholder="Enter doctor name" />
                    <span asp-validation-for="DoctorName" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="OwnerName" class="form-label"> Owner Name </label>
                    <input asp-for="OwnerName" class="form-control" placeholder="Enter owner name" />
                    <span asp-validation-for="OwnerName" class="text-danger"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Status" class="form-label">Status</label>

                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<AppointmentStatus>()">
                    </select>

                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

            </div>
 
            <div class="mb-4">
                <label asp-for="ReasonForVisit" class="form-label"> Reason For Visit </label>
                <textarea asp-for="ReasonForVisit" class="form-control" placeholder="Enter reason for visit"></textarea>
                <span asp-validation-for="ReasonForVisit" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="DoctorNotes" class="form-label"> Doctor Notes </label>
                <textarea asp-for="DoctorNotes" class="form-control" placeholder="Enter doctor notes"></textarea>
                <span asp-validation-for="DoctorNotes" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-center mt-4">
                <button type="submit"
                        class="btn btn-primary"
                        style="width: 220px; height: 45px;">
                    Update Appointment
                </button>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

}