<style>
    .timeline-card {
        display: flex;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        margin-bottom: 15px;
        transition: 0.3s ease;
    }

        .timeline-card:hover {
            transform: translateY(-4px);
        }

    /* LEFT TIME SECTION */
    .time-section {
        width: 110px;
        background: linear-gradient(135deg, #0d6efd, #6ea8fe);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 15px;
        position: relative;
    }

        .time-section .time {
            font-size: 18px;
            font-weight: 700;
            text-align: center;
        }

        .time-section .icon {
            margin-top: 10px;
            width: 34px;
            height: 34px;
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    /* RIGHT CONTENT */
    .content-section {
        flex: 1;
        padding: 14px 16px;
        position: relative;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .title {
        margin: 0;
        font-weight: 600;
    }

    .subtitle {
        margin: 6px 0 10px;
        font-size: 13px;
        opacity: 0.75;
    }

    .menu {
        color: #999;
        cursor: pointer;
    }

    .footer {
        font-size: 12px;
        color: #666;
    }

    .timeline-card.urgent .time-section {
        background: linear-gradient(135deg, #ff4d4d, #ff9900);
    }

    .timeline-card.success .time-section {
        background: linear-gradient(135deg, #28a745, #20c997);
    }

    .stat-card-link {
        text-decoration: none !important;
        color: inherit !important;
        display: block;
    }

        .stat-card-link:hover {
            text-decoration: none !important;
            color: inherit !important;
        }

    .stat-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .stat-card-link:hover .stat-card {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
    }
</style>


