<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Detail Page Editable</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .detail-header {
        background: linear-gradient(135deg, #0d6efd, #6ea8fe);
        border-radius: 16px;
        padding: 20px;
        color: white;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .icon-box {
        width: 55px;
        height: 55px;
        background: rgba(255,255,255,0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .detail-card {
        border-radius: 16px;
        border: none;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    }

    label {
        font-size: 12px;
        color: #888;
        margin-bottom: 2px;
        display: block;
    }

    .edit-mode {
        display: none;
        width: 100%;
    }

    .view-mode {
        display: block;
    }

    textarea.edit-mode {
        min-height: 90px;
    }
</style>
</head>

<body>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="detail-header shadow-sm">
        <div class="icon-box">
            <i class="bi bi-heart-pulse-fill"></i>
        </div>
        <div>
            <h4 class="mb-1">Final Checkup</h4>
            <small class="text-light opacity-75">Lily – Recovery review</small>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="card detail-card mt-4">
        <div class="card-body">

            <!-- INFO GRID -->
            <div class="row g-4">

                <div class="col-md-6">
                    <label>Date</label>

                    <p class="view-mode"><i class="bi bi-calendar"></i> 20 May 2026</p>
                    <input class="form-control edit-mode" value="20 May 2026">
                </div>

                <div class="col-md-6">
                    <label>Time</label>

                    <p class="view-mode"><i class="bi bi-clock"></i> 4:30 PM</p>
                    <input class="form-control edit-mode" value="4:30 PM">
                </div>

                <div class="col-md-6">
                    <label>Treatment</label>

                    <p class="view-mode"><i class="bi bi-geo-alt"></i> Check Up</p>
                    <input class="form-control edit-mode" value="Check Up">
                </div>

                <div class="col-md-6">
                    <label>Status</label>

                    <p class="view-mode">
                        <span class="badge bg-warning text-dark">Upcoming</span>
                    </p>

                    <select class="form-select edit-mode">
                        <option>Upcoming</option>
                        <option>Completed</option>
                        <option>Cancelled</option>
                    </select>
                </div>

            </div>

            <hr />

            <!-- DESCRIPTION -->
            <div>
                <label>Description</label>

                <p class="text-muted view-mode">
                    This is the final recovery checkup after surgery.
                    Ensure proper healing and monitor vitals.
                </p>

                <textarea class="form-control edit-mode">This is the final recovery checkup after surgery.Ensure proper healing and monitor vitals.</textarea>
            </div>

            <!-- NOTES -->
            <div class="mt-3">
                <label>Notes</label>

                <p class="text-muted view-mode">
                    Pet is recovering well. Keep activity limited.
                </p>

                <textarea class="form-control edit-mode">Pet is recovering well. Keep activity limited.</textarea>
            </div>

                <div class="d-flex justify-content-center mt-4">
                    <div class="d-flex gap-2 w-100" style="max-width: 600px;">

                        <button id="editBtn" class="btn btn-primary flex-fill">
                            Edit
                        </button>

                        <button id="saveBtn" class="btn btn-success flex-fill" style="display:none;">
                            Save
                        </button>

                        <button id="cancelBtn" class="btn btn-secondary flex-fill" style="display:none;">
                            Cancel
                        </button>

                        <button class="btn btn-success flex-fill">
                            Mark as Done
                        </button>

                    </div>
                </div>
        </div>
    </div>

</div>

<script>
const editBtn = document.getElementById("editBtn");
const saveBtn = document.getElementById("saveBtn");
const cancelBtn = document.getElementById("cancelBtn");

function toggleEdit(isEdit) {

    document.querySelectorAll(".view-mode").forEach(el => {
        el.style.display = isEdit ? "none" : "block";
    });

    document.querySelectorAll(".edit-mode").forEach(el => {
        el.style.display = isEdit ? "block" : "none";
    });

    editBtn.style.display = isEdit ? "none" : "inline-block";
    saveBtn.style.display = isEdit ? "inline-block" : "none";
    cancelBtn.style.display = isEdit ? "inline-block" : "none";
}

editBtn.addEventListener("click", () => toggleEdit(true));
cancelBtn.addEventListener("click", () => toggleEdit(false));
</script>

</body>
</html>