@model PrimaryVets.Models.PetRegisterViewModel
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<button class="back-btn"
        onclick="history.back()">
    <i class="bi bi-arrow-left"></i>
</button>
<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-lg-12">

            <!-- CARD -->
            <div class="card shadow-sm border-1 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <img src="~/images/Prime_vets_logo.png"
                             alt="Logo"
                             class="me-3"
                             style="height:60px; width:auto;" />
                        <div>
                            <h2 class="mb-0 fw-bold">Pet REPORTS</h2>
                            <small class="text-muted">Add pet reports</small>
                        </div>

                    </div>

                    <form method="post" asp-action="Create2" asp-controller="PetRegistration">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label>Reports</label>
                            <input type="file" name="Image" class="form-control" accept="image/*, application/pdf" multiple required/>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Remarks</label>
                            <textarea name="Notes" class="form-control" rows="3" ></textarea>
                        </div>
                        <!-- ACTIONS -->
                        <div class="d-flex justify-content-end gap-2">
                            <a class="btn btn-dark border"
                               asp-action="Index"
                               asp-controller="PetRegistration">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-success">Save</button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>