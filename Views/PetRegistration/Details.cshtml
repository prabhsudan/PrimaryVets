<style>
    body {
        background: #f5f7fb;
    }

    .pet-card {
        max-width: 700px;
        margin: auto;
        border: none;
        border-radius: 16px;
        overflow: visible;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        background: white;
    }

    /* HEADER FIX */
    .pet-header {
        background: linear-gradient(135deg, #396afc, #2948ff);
        padding: 40px 20px 70px; /* extra bottom space for avatar */
        text-align: center;
        color: white;
        position: relative;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }

    .pet-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .pet-subtitle {
        font-size: 14px;
        opacity: 0.9;
    }

    /* AVATAR FIX */
    .pet-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid white;
        position: absolute;
        left: 50%;
        bottom: -60px;
        transform: translateX(-50%);
        box-shadow: 0 6px 15px rgba(0,0,0,0.25);
        background: white;
    }

    /* BODY FIX */
    .pet-body {
        padding: 80px 25px 25px; /* pushes content below avatar */
        background: white;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .info-box {
        background: #f9fafb;
        padding: 12px 15px;
        border-radius: 10px;
        border: 1px solid #eee;
    }

    .label {
        font-size: 12px;
        color: #6b7280;
    }

    .value {
        font-weight: 600;
        color: #111;
    }

    .header-bar {
        position: sticky;
        top: 0;
        background: #fff;
        z-index: 100;
        display: flex;
        align-items: center;
        height: 60px;
    }

    /* Back button stays left */
    .back-btn {
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: #f5f7fb;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    /* PERFECT CENTER TITLE */
    .page-title {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-size: 18px;
        font-weight: 700;
        margin: 0;
    }
</style>
<div class="sticky-top bg-white border-bottom py-2 px-3 header-bar">

    <button class="back-btn"
            onclick="history.back()">
        <i class="bi bi-arrow-left"></i>
    </button>

    <h2 class="page-title mb-0" style="font-size:20px">
        Pet Details
    </h2>

</div>
<br />
<div class="card pet-card">

    <!-- HEADER -->
    <div class="pet-header">
        <div class="pet-title">Tommy</div>
        <div class="pet-subtitle">Labrador • Dog • 3 Years</div>

        <!-- AVATAR -->
        <img src="~/images/Tommy.jpg" class="pet-avatar" />
    </div>

    <!-- BODY -->
    <div class="pet-body">

        <div class="info-grid">

            <div class="info-box">
                <div class="label">Owner</div>
                <div class="value">Sarah Jenkins</div>
            </div>

            <div class="info-box">
                <div class="label">Mobile</div>
                <div class="value">123-456-7890</div>
            </div>

            <div class="info-box">
                <div class="label">Treatment</div>
                <div class="value">Vaccination</div>
            </div>

            <div class="info-box">
                <div class="label">Injuries</div>
                <div class="value">None</div>
            </div>

        </div>

    </div>
</div>