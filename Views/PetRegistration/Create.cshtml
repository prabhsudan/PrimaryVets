@model PrimaryVets.Models.PetRegisterViewModel
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .filter-chip {
            transition: all 0.2s ease-in-out;
            min-height: 38px;
            white-space: nowrap;
            margin-bottom:0px;
        }

            /* ONLY SELECTED CHIPS */
            .filter-chip.active {
                height: 25px !important;
                min-height: 25px !important;
                padding: 0 8px !important;
                font-size: 11px !important;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 4px !important;
                white-space: nowrap;
                margin-right: 6px;
            }

                /* keep close icon small */
                .filter-chip.active .btn-close {
                    font-size: 0.45rem !important;
                    margin-left: 4px;
                }
        .mic-active {
            background-color: #0d6efd !important;
            color: white !important;
            border-color: #0d6efd !important;
        }

            .mic-active i {
                color: white !important;
            }
    </style>

</head>
<div class="container py-2">

    <div class="row justify-content-center">
        <div class="col-lg-12">

            <!-- CARD -->
            <div class="card shadow-sm border-1 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <img src="~/images/Prime_vets_logo.png"
                             alt="Logo"
                             class="me-3"
                             style="height:60px; width:auto;" />
                        <div>
                            <h2 class="mb-0 fw-bold">Pet Registration</h2>
                            <small class="text-muted">Add new pet & owner details</small>
                        </div>

                    </div>

                    <form method="post" asp-action="Create" asp-controller="PetRegistration">
                        @Html.AntiForgeryToken()

                        <div class="d-flex mb-3">
                            <button type="button" id="micBtn" class="btn btn-outline-primary d-flex align-items-center gap-2"
                                    onclick="startVoice(null, this)">
                                <i class="bi bi-mic-fill"></i>
                                <span id="micBtnText">Speak</span>
                            </button>

                            <button type="button" id="stopBtn" class="btn btn-danger d-flex align-items-center gap-2 ms-2 d-none"
                                    onclick="stopVoice()">
                                <i class="bi bi-stop-fill"></i>
                                Stop
                            </button>
                        </div>

                        <!-- OWNER + PET -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Owner Name</label>
                                <input type="text" name="Name" id="Name" class="form-control" required maxlength="15" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Pet Name</label>
                                <input type="text" name="PetName" id="PetName" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Species</label>
                                <select name="Species" id="Species" class="form-select" required>
                                    <option value="">Select Species</option>
                                    <option value="Dog">Dog</option>
                                    <option value="Cat">Cat</option>
                                    <option value="Bird">Bird</option>
                                    <option value="Rabbit">Rabbit</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div id="other-species-container" class="mt-2 d-none">
                                <label class="form-label small text-muted" for="OtherSpecies">Please specify species</label>
                                <input type="text" name="OtherSpecies" id="OtherSpecies" class="form-control" autocomplete="off" placeholder="e.g., Hamster, Ferret" />
                            </div>
                        </div>

                        <!-- TYPE / GENDER -->
                        <div class="row g-3 mb-3">
                            

                            <div class="col-md-4">
                                <label class="form-label">Gender</label>
                                <select name="Gender" id="Gender" class="form-select" required>
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Age</label>
                                <input type="text" name="Age" id="Age" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Body Temperature</label>
                                <input type="text" name="BodyTemperature" id="BodyTemperature" class="form-control" required />
                            </div>

                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Weight</label>
                                <input type="text" name="Weight" id="Weight" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Breed</label>
                                <input type="text" name="Breed" id="Breed" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Pet Behavior</label>
                                <select name="PetBehaviour" id="PetBehaviour" class="form-select" required>
                                    <option value="">Select Behaviour</option>
                                    <option value="Calm">Calm</option>
                                    <option value="Aggressive">Aggressive</option>
                                    <option value="Playful">Playful</option>
                                </select>
                            </div>
                        </div>
                       
                        <div class="row g-3 mb-3">

                            <div class="col-md-2">
                                <label class="form-label">Country Code</label>
                                <select name="CountryCode" id="CountryCode" class="form-select" required>
                                    <option value="+91">+91</option>
                                    <option value="+1">+1</option>
                                    <option value="+44">+44</option>
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Mobile</label>
                                <input type="text" name="Mobile" id="Mobile" class="form-control" required />
                            </div>

                            <div class="col-md-7">
                                <label class="form-label">Treatment</label>
                                <select name="Treatment" id="Treatment" class="form-select" required>
                                    <option value="">Select Treatment</option>
                                    <option value="Vaccination">Vaccination</option>
                                    <option value="Surgery">Surgery</option>
                                    <option value="Checkup">Checkup</option>
                                    <option value="Emergency">Emergency</option>
                                </select>
                            </div>

                        </div>

                        <div class="mb-3" id="filter-section">

                            <!-- LABEL + SELECTED -->
                            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                <label class="form-label fw-semibold mb-0" for="active-chips-container">
                                    Tests: <span class="text-danger">*</span>
                                </label>
                                <div id="active-chips-container" class="d-flex flex-wrap">
                                </div>
                            </div>

                            <div id="hidden-inputs-container" style="position: absolute; width: 0; height: 0; opacity: 0; overflow: hidden;">
                            </div>

                            <!-- AVAILABLE CHIPS -->
                            <div id="inactive-chips-container" class="d-flex flex-wrap gap-2">

                                <button type="button"
                                        class="btn btn-outline-primary px-3 filter-chip d-inline-flex align-items-center"
                                        data-value="PCR">
                                    <span class="filter-text">PCR</span>
                                    <span class="btn-close btn-close-white ms-2 d-none" aria-label="Close"></span>
                                </button>

                                <button type="button"
                                        class="btn btn-outline-primary filter-chip d-inline-flex align-items-center"
                                        data-value="ELISA">
                                    <span class="filter-text">ELISA</span>
                                    <span class="btn-close btn-close-white ms-2 d-none" aria-label="Close"></span>
                                </button>

                                <button type="button"
                                        class="btn btn-outline-primary px-3 filter-chip d-inline-flex align-items-center"
                                        data-value="SNAP Tests">
                                    <span class="filter-text">SNAP Tests</span>
                                    <span class="btn-close btn-close-white ms-2 d-none" aria-label="Close"></span>
                                </button>

                                <button type="button"
                                        class="btn btn-outline-primary px-3 filter-chip d-inline-flex align-items-center"
                                        data-value="Titer Testing">
                                    <span class="filter-text">Titer Testing</span>
                                    <span class="btn-close btn-close-white ms-2 d-none" aria-label="Close"></span>
                                </button>

                            </div>
                        </div>
                        <div class="d-flex mb-3">
                            <button type="button" id="micNotesBtn" class="btn btn-outline-primary d-flex align-items-center gap-2"
                                    onclick="startNotesVoice(this)">
                                <span id="micNotesText">Speak Notes</span>
                            </button>

                            <button type="button" id="stopBtnNotes" class="btn btn-danger d-flex align-items-center gap-2 ms-2 d-none"
                                    onclick="stopVoiceNotes()">
                                Stop
                            </button>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" id="Notes" class="form-control" rows="2"></textarea>
                        </div>
                        
                        <div class="d-flex justify-content-end gap-2">
                            <a class="btn btn-dark" asp-action="Index" asp-controller="PetRegistration">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-success">Next</button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>
@section Scripts {
    <script src="/js/whisper.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const speciesSelect = document.getElementById("Species");
            const otherContainer = document.getElementById("other-species-container");
            const otherInput = document.getElementById("OtherSpecies");

            function checkSpeciesValue() {
                if (speciesSelect.value === "Other") {
                    otherContainer.classList.remove("d-none");
                    otherInput.required = true;
                    otherInput.focus();
                } else {
                    otherContainer.classList.add("d-none");
                    otherInput.required = false;
                    otherInput.value = ""; 
                }
            }

            speciesSelect.addEventListener("change", checkSpeciesValue);
            checkSpeciesValue();
        });

        const activeContainer = document.getElementById('active-chips-container');
        const inactiveContainer = document.getElementById('inactive-chips-container');
        const hiddenInputsContainer = document.getElementById('hidden-inputs-container');

        function updateHiddenInputs() {
            if (!hiddenInputsContainer) return;
            hiddenInputsContainer.innerHTML = '';
            const activeChips = activeContainer.querySelectorAll('.filter-chip');

            if (activeChips.length === 0) {
                const validationInput = document.createElement('input');
                validationInput.type = 'checkbox';
                validationInput.required = true;
                validationInput.name = "SelectedTestsRequiredCheck";
                validationInput.setCustomValidity("Please select at least one Test.");
                hiddenInputsContainer.appendChild(validationInput);
            } else {
                activeChips.forEach(chip => {
                    const val = chip.getAttribute('data-value') || chip.getAttribute('data-full-text');
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = "SelectedTests"; 
                    input.value = val;
                    hiddenInputsContainer.appendChild(input);
                });
            }
            saveChipsToStorage();
        }

        function saveChipsToStorage() {
            const activeValues = [];
            activeContainer.querySelectorAll('.filter-chip').forEach(chip => {
                const val = chip.getAttribute('data-value') || chip.getAttribute('data-full-text');
                activeValues.push(val);
            });
            sessionStorage.setItem('selectedPetTests', JSON.stringify(activeValues));
        }

        function loadChipsFromStorage() {
            const saved = sessionStorage.getItem('selectedPetTests');
            if (!saved) {
                updateHiddenInputs();
                return;
            }

            const activeValues = JSON.parse(saved);
            document.querySelectorAll('.filter-chip').forEach(button => {
                const crossSign = button.querySelector('.btn-close');
                const filterText = button.querySelector('.filter-text');
                const currentVal = button.getAttribute('data-value') || button.getAttribute('data-full-text');

                if (activeValues.includes(currentVal) && !button.classList.contains('active')) {
                    button.classList.add('active');
                    crossSign.classList.remove('d-none');
                    if (filterText.textContent.trim() === 'SNAP Tests') filterText.textContent = 'SNAP';
                    if (filterText.textContent.trim() === 'Titer Testing') filterText.textContent = 'Titer';
                    activeContainer.appendChild(button);
                }
            });
            updateHiddenInputs();
        }

        document.querySelectorAll('.filter-chip').forEach(button => {
            const crossSign = button.querySelector('.btn-close');
            const filterText = button.querySelector('.filter-text');

            button.setAttribute('data-full-text', filterText.textContent.trim());

            button.addEventListener('click', function(e) {
                if (e.target.classList.contains('btn-close')) {
                    e.stopPropagation();
                    deactivateChip(this, crossSign, filterText);
                    return;
                }
                if (!this.classList.contains('active')) {
                    this.classList.add('active');
                    crossSign.classList.remove('d-none');
                    if (filterText.textContent.trim() === 'SNAP Tests') filterText.textContent = 'SNAP';
                    if (filterText.textContent.trim() === 'Titer Testing') filterText.textContent = 'Titer';
                    activeContainer.appendChild(this);
                    updateHiddenInputs();
                }
            });
        });

        function deactivateChip(button, cross, textSpan) {
            button.classList.remove('active');
            cross.classList.add('d-none');
            textSpan.textContent = button.getAttribute('data-full-text');
            inactiveContainer.appendChild(button);
            updateHiddenInputs();
        }

        document.getElementById('clearAllBtn')?.addEventListener('click', () => {
            document.querySelectorAll('.filter-chip').forEach(button => {
                const crossSign = button.querySelector('.btn-close');
                const filterText = button.querySelector('.filter-text');
                deactivateChip(button, crossSign, filterText);
            });
        });

        window.addEventListener('pageshow', loadChipsFromStorage);
    </script>

}
